# Copy to .env and fill in. Never commit your real .env.

# The full URL of the Airtable employee timesheet interface.
# Example: https://airtable.com/appXXXXXXXXXXXXXX/pagYYYYYYYYYYYYYY
AIRTABLE_INTERFACE_URL=https://airtable.com/appXXXXXXXXXXXXXX/pagYYYYYYYYYYYYYY

# How many concurrent virtual users to simulate (matches the team's 18-20 target).
PW_CONCURRENT_USERS=20

# Set to 'false' to watch the browser windows (useful while debugging selectors).
PW_HEADLESS=true

# Use installed Google Chrome instead of Playwright's bundled Chromium.
# Airtable blocks the bundled browser and the timesheet iframe never loads.
PW_CHANNEL=chrome

# Path (relative to playwright_tests/) to the JSON file describing your test users.
# See users.example.json for the expected shape.
PW_USERS_FILE=users.json

# When the user pool is smaller than PW_CONCURRENT_USERS, set this to 'true' to
# reuse the same auth states across multiple browser contexts. This stresses the
# *interface* but does not produce N distinct Airtable sessions; use real
# accounts for true multi-user load.
PW_ALLOW_REUSE=true

# Soak duration in milliseconds for the concurrent run. Each virtual user keeps
# polling/interacting for this long after page load before tearing down.
PW_SOAK_MS=60000

# Optional: target Monday (YYYY-MM-DD) the load test should select on the week
# picker. Leave blank to use whichever week the interface defaults to.
PW_TARGET_WEEK_MONDAY=
